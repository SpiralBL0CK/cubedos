
message struct -> M_Request {
  int M1;
  int M2;
} with Message_Invariant => (M1 = M2);

message struct -> M_Request {
  int M1;
  int M2;
} with Message_Invariant => (M1 /= M2);

message struct -> M_Request {
  int M1;
  int M2;
} with Message_Invariant => (M1 <= M2);

message struct -> M_Request {
  int M1;
  int M2;
} with Message_Invariant => (M1 >= M2);

message struct -> M_Request {
  int M1;
  int M2;
} with Message_Invariant => (M1 < M2);

message struct -> M_Request {
  int M1;
  int M2;
} with Message_Invariant => (M1 > M2);

